# ============================================================
# SWD x Videogen Bot - Environment Configuration
# Salin file ini ke .env lalu isi nilai yang kosong.
# ============================================================

# Token Bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=

# User ID admin Telegram (dapatkan dari @userinfobot)
ADMIN_USER_ID=

# Harga per akun dalam Rupiah (fallback, produk punya harga sendiri)
HARGA_PER_AKUN=10000

# Nama toko/bot
SHOP_NAME=SWD x Videogen

# Lokasi database SQLite (disimpan di volume persisten)
DB_PATH=/app/data/bot.db

# ============================================================
# KlikQRIS Payment Gateway — PG KlikQRIS (Production)
# Daftar gratis di https://klikqris.com
# ============================================================
# API Key dari dashboard KlikQRIS > Pengaturan
KLIKQRIS_API_KEY=
# Merchant ID dari dashboard KlikQRIS
KLIKQRIS_MERCHANT_ID=
# Mode: production
KLIKQRIS_MODE=production
# Callback URL (otomatis dari WEBHOOK_URL jika kosong)
# Contoh: https://keok69.biz.id/webhook/klikqris
KLIKQRIS_CALLBACK_URL=

# ============================================================
# Webhook Config (set USE_WEBHOOK=true untuk production)
# ============================================================
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_PORT=8080

# Admin IDs tambahan (koma-separated, opsional)
EXTRA_ADMIN_IDS=
